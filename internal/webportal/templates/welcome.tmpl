{{define "content"}}
<section class="panel">
  <h2>Welcome</h2>
  <p>This local portal is the primary setup and status interface for LoRaMapr Receiver.</p>
  <div class="status-grid">
    <div class="status-chip"><div class="label">Pairing</div><div class="value">{{.Snapshot.PairingPhase}}</div></div>
    <div class="status-chip"><div class="label">Cloud</div><div class="value">{{.Snapshot.CloudStatus}}</div></div>
    <div class="status-chip"><div class="label">Service</div><div class="value">{{.Snapshot.Lifecycle}}</div></div>
    <div class="status-chip"><div class="label">Ready</div><div class="value">{{if .Snapshot.Ready}}yes{{else}}no{{end}}</div></div>
    <div class="status-chip"><div class="label">Failure</div><div class="value mono">{{if .Snapshot.FailureCode}}{{.Snapshot.FailureCode}}{{else}}none{{end}}</div></div>
  </div>
  {{if .SummaryHint}}
  <div class="hint {{.SummaryHintClass}}">{{.SummaryHint}}</div>
  {{end}}
</section>
<section class="panel">
  <h2>Next Step</h2>
  <p>{{.NextAction}}</p>
  <p class="muted">If you have a pairing code from LoRaMapr Cloud, continue to the Pairing page.</p>
</section>
{{end}}
