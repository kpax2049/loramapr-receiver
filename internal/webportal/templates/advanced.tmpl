{{define "content"}}
<section class="panel">
  <h2>Advanced Details</h2>
  <p class="muted">Use this page for support/debug metadata. Most setup tasks are handled in Pairing, Progress, and Troubleshooting.</p>
  <table>
    <tr><th>Installation ID</th><td class="mono">{{if .Snapshot.InstallationID}}{{.Snapshot.InstallationID}}{{else}}unknown{{end}}</td></tr>
    <tr><th>Local Receiver Name</th><td>{{if .Snapshot.LocalName}}{{.Snapshot.LocalName}}{{else}}unnamed{{end}}</td></tr>
    <tr><th>Hostname</th><td class="mono">{{if .Snapshot.Hostname}}{{.Snapshot.Hostname}}{{else}}unknown{{end}}</td></tr>
    <tr><th>Cloud Receiver ID</th><td class="mono">{{if .Snapshot.CloudReceiverID}}{{.Snapshot.CloudReceiverID}}{{else}}not assigned{{end}}</td></tr>
    <tr><th>Cloud Receiver Name</th><td>{{if .Snapshot.CloudReceiverLabel}}{{.Snapshot.CloudReceiverLabel}}{{else}}not assigned{{end}}</td></tr>
    <tr><th>Optional Cloud Labels</th><td>{{if or .Snapshot.CloudSiteLabel .Snapshot.CloudGroupLabel}}site={{if .Snapshot.CloudSiteLabel}}{{.Snapshot.CloudSiteLabel}}{{else}}not set{{end}}, group={{if .Snapshot.CloudGroupLabel}}{{.Snapshot.CloudGroupLabel}}{{else}}not set{{end}}{{else}}none{{end}}</td></tr>
    <tr><th>Runtime Version</th><td class="mono">{{.RuntimeVersion}}</td></tr>
    <tr><th>Release Channel</th><td class="mono">{{.ReleaseChannel}}</td></tr>
    <tr><th>Build Commit</th><td class="mono">{{if .BuildCommit}}{{.BuildCommit}}{{else}}unknown{{end}}</td></tr>
    <tr><th>Build Date</th><td class="mono">{{if .BuildDate}}{{.BuildDate}}{{else}}unknown{{end}}</td></tr>
    <tr><th>Build ID</th><td class="mono">{{if .BuildID}}{{.BuildID}}{{else}}unknown{{end}}</td></tr>
    <tr><th>Go Version</th><td class="mono">{{.GoVersion}}</td></tr>
    <tr><th>Platform</th><td class="mono">{{.Platform}}/{{.Arch}}</td></tr>
    <tr><th>Install Type</th><td class="mono">{{if .InstallType}}{{.InstallType}}{{else}}unknown{{end}}</td></tr>
    <tr><th>Service Mode</th><td class="mono">{{.Snapshot.Mode}}</td></tr>
    <tr><th>Runtime Profile</th><td class="mono">{{.Snapshot.RuntimeProfile}}</td></tr>
    <tr><th>Meshtastic Config Available</th><td>{{if .Snapshot.MeshtasticConfig.Available}}yes{{else}}no{{end}}</td></tr>
    <tr><th>Meshtastic Region</th><td class="mono">{{if .Snapshot.MeshtasticConfig.Region}}{{.Snapshot.MeshtasticConfig.Region}}{{else}}unknown{{end}}</td></tr>
    <tr><th>Meshtastic Primary Channel</th><td>{{if .Snapshot.MeshtasticConfig.PrimaryChannel}}{{.Snapshot.MeshtasticConfig.PrimaryChannel}}{{else}}unknown{{end}}</td></tr>
    <tr><th>Meshtastic PSK State</th><td class="mono">{{if .Snapshot.MeshtasticConfig.PSKState}}{{.Snapshot.MeshtasticConfig.PSKState}}{{else}}unknown{{end}}</td></tr>
    <tr><th>Meshtastic Share URL Available</th><td>{{if .Snapshot.MeshtasticConfig.ShareURLAvailable}}yes{{else}}no{{end}}</td></tr>
    <tr><th>Meshtastic Share URL (Redacted)</th><td class="mono">{{if .Snapshot.MeshtasticConfig.ShareURLRedacted}}{{.Snapshot.MeshtasticConfig.ShareURLRedacted}}{{else}}none{{end}}</td></tr>
    <tr><th>Meshtastic Config Source</th><td class="mono">{{if .Snapshot.MeshtasticConfig.Source}}{{.Snapshot.MeshtasticConfig.Source}}{{else}}unknown{{end}}</td></tr>
    <tr><th>Meshtastic Config Updated</th><td class="mono">{{if .Snapshot.MeshtasticConfig.UpdatedAt}}{{.Snapshot.MeshtasticConfig.UpdatedAt}}{{else}}unknown{{end}}</td></tr>
    <tr><th>Update Status</th><td class="mono">{{if .Snapshot.UpdateStatus}}{{.Snapshot.UpdateStatus}}{{else}}unknown{{end}}</td></tr>
    <tr><th>Recommended Version</th><td class="mono">{{if .Snapshot.UpdateRecommendedVersion}}{{.Snapshot.UpdateRecommendedVersion}}{{else}}unknown{{end}}</td></tr>
    <tr><th>Manifest Channel</th><td class="mono">{{if .Snapshot.UpdateManifestChannel}}{{.Snapshot.UpdateManifestChannel}}{{else}}unknown{{end}}</td></tr>
    <tr><th>Last Update Check</th><td class="mono">{{if .Snapshot.UpdateCheckedAt}}{{.Snapshot.UpdateCheckedAt}}{{else}}never{{end}}</td></tr>
    <tr><th>Lifecycle</th><td>{{.Snapshot.Lifecycle}}</td></tr>
  </table>
</section>
<section class="panel">
  <h2>Security Notes</h2>
  <p class="muted">This page intentionally omits stored API secrets and activation tokens. Meshtastic share values are shown only on local portal surfaces; redacted values are used for support exports and cloud status.</p>
</section>
{{end}}
