{{define "content"}}
<section class="panel">
  <h2>Troubleshooting</h2>
  <p>Use these checks before escalating support issues.</p>
  {{if .Snapshot.FailureCode}}
  <div class="hint err">
    <strong>{{.Snapshot.FailureCode}}</strong>: {{.Snapshot.FailureSummary}}
    {{if .Snapshot.FailureHint}}<br>{{.Snapshot.FailureHint}}{{end}}
  </div>
  {{end}}
  <ul>
    {{range .TroubleshootingHints}}
    <li>{{.}}</li>
    {{end}}
  </ul>
</section>
<section class="panel">
  <h2>Operational Status</h2>
  <p><strong>{{if .OperationalOverall}}{{.OperationalOverall}}{{else}}unknown{{end}}</strong>{{if .OperationalSummary}}: {{.OperationalSummary}}{{end}}</p>
  <table>
    <tr><th>Check</th><th>Level</th><th>Summary</th><th>Guidance</th></tr>
    {{range .OperationalChecks}}
    <tr>
      <td class="mono">{{.ID}}</td>
      <td class="mono">{{.Level}}</td>
      <td>{{.Summary}}</td>
      <td>{{if .Hint}}{{.Hint}}{{else}}-{{end}}</td>
    </tr>
    {{end}}
  </table>
</section>
<section class="panel">
  <h2>Lifecycle Actions</h2>
  <p>If receiver credentials were revoked, disabled, or replaced, reset local credentials and re-pair.</p>
  <form method="post" action="/reset">
    <input type="hidden" name="deauthorize" value="1">
    <button type="submit">Reset And Re-pair</button>
  </form>
</section>
<section class="panel">
  <h2>Health Endpoints</h2>
  <table>
    <tr><th>Liveness</th><td><span class="mono">GET /healthz</span></td></tr>
    <tr><th>Readiness</th><td><span class="mono">GET /readyz</span></td></tr>
    <tr><th>Structured Status</th><td><span class="mono">GET /api/status</span></td></tr>
    <tr><th>Operational Checks</th><td><span class="mono">GET /api/ops</span></td></tr>
  </table>
</section>
{{end}}
