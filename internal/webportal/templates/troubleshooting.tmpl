{{define "content"}}
<section class="panel">
  <h2>Troubleshooting</h2>
  <p>Use this page when pairing is stuck, cloud is offline, node is missing, or packets are not forwarding.</p>
  {{if .Snapshot.FailureCode}}
  <div class="hint err">
    <strong>{{.Snapshot.FailureCode}}</strong>: {{.Snapshot.FailureSummary}}
    {{if .Snapshot.FailureHint}}<br>{{.Snapshot.FailureHint}}{{end}}
  </div>
  {{end}}
  {{if and .Attention.State (ne .Attention.State "none")}}
  <div class="hint {{if eq .Attention.State "urgent"}}err{{else if eq .Attention.State "action_required"}}warn{{else}}none{{end}}">
    <strong>Attention {{.Attention.State}}</strong>{{if .Attention.Code}} ({{.Attention.Code}}){{end}}
    {{if .Attention.Summary}}: {{.Attention.Summary}}{{end}}
    {{if .Attention.Hint}}<br>{{.Attention.Hint}}{{end}}
  </div>
  {{end}}
  <ul>
    {{range .TroubleshootingHints}}
    <li>{{.}}</li>
    {{end}}
  </ul>
</section>
<section class="panel">
  <h2>Operational Status</h2>
  <p><strong>{{if .OperationalOverall}}{{.OperationalOverall}}{{else}}unknown{{end}}</strong>{{if .OperationalSummary}}: {{.OperationalSummary}}{{end}}</p>
  <table>
    <tr><th>Check</th><th>Level</th><th>Summary</th><th>Guidance</th></tr>
    {{range .OperationalChecks}}
    <tr>
      <td class="mono">{{.ID}}</td>
      <td class="mono">{{.Level}}</td>
      <td>{{.Summary}}</td>
      <td>{{if .Hint}}{{.Hint}}{{else}}-{{end}}</td>
    </tr>
    {{end}}
  </table>
</section>
<section class="panel">
  <h2>Lifecycle Actions</h2>
  <p>If this receiver was revoked, disabled, or replaced in cloud, reset local credentials and pair again.</p>
  <form method="post" action="/reset">
    <input type="hidden" name="deauthorize" value="1">
    <button type="submit">Reset And Re-pair</button>
  </form>
</section>
<section class="panel">
  <h2>Advanced Local Endpoints</h2>
  <p class="muted">These endpoints are mainly for local diagnostics tooling and support workflows.</p>
  <table>
    <tr><th>Liveness</th><td><span class="mono">GET /healthz</span></td></tr>
    <tr><th>Readiness</th><td><span class="mono">GET /readyz</span></td></tr>
    <tr><th>Structured Status</th><td><span class="mono">GET /api/status</span></td></tr>
    <tr><th>Operational Checks</th><td><span class="mono">GET /api/ops</span></td></tr>
  </table>
</section>
{{end}}
