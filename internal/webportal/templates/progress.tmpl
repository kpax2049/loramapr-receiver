{{define "content"}}
<section class="panel">
  <h2>Receiver Progress</h2>
  <p>Use this page to confirm pairing, cloud reachability, node connection, and forwarding activity.</p>
  {{if .Flash}}
  <div class="hint {{.FlashClass}}">{{.Flash}}</div>
  {{end}}
  <div class="status-grid">
    <div class="status-chip"><div class="label">Local Receiver Name</div><div class="value">{{if .Snapshot.LocalName}}{{.Snapshot.LocalName}}{{else}}unnamed{{end}}</div></div>
    <div class="status-chip"><div class="label">Cloud Receiver</div><div class="value">{{if .Snapshot.CloudReceiverLabel}}{{.Snapshot.CloudReceiverLabel}}{{else if .Snapshot.CloudReceiverID}}{{.Snapshot.CloudReceiverID}}{{else}}not assigned{{end}}</div></div>
    <div class="status-chip"><div class="label">Pairing State</div><div class="value mono">{{.Snapshot.PairingPhase}}</div></div>
    <div class="status-chip"><div class="label">Cloud Connectivity</div><div class="value">{{.Snapshot.CloudStatus}}</div></div>
    <div class="status-chip"><div class="label">Network</div><div class="value">{{.NetworkState}}</div></div>
    <div class="status-chip"><div class="label">Service State</div><div class="value">{{.Snapshot.Lifecycle}}</div></div>
    <div class="status-chip"><div class="label">Meshtastic Status</div><div class="value">{{.MeshtasticState}}</div></div>
    <div class="status-chip"><div class="label">Update Status</div><div class="value mono">{{if .Snapshot.UpdateStatus}}{{.Snapshot.UpdateStatus}}{{else}}unknown{{end}}</div></div>
    <div class="status-chip"><div class="label">Issue Code</div><div class="value mono">{{if .Snapshot.FailureCode}}{{.Snapshot.FailureCode}}{{else}}none{{end}}</div></div>
    <div class="status-chip">
      <div class="label">Attention</div>
      <div class="value">
        {{if and .Attention.State (ne .Attention.State "none")}}
          <span class="badge {{.Attention.State}}">{{.Attention.State}}</span>
          {{if .Attention.Code}} <span class="mono">{{.Attention.Code}}</span>{{end}}
        {{else}}
          none
        {{end}}
      </div>
    </div>
  </div>
  {{if and .Attention.State (ne .Attention.State "none")}}
  <div class="hint {{if eq .Attention.State "urgent"}}err{{else if eq .Attention.State "action_required"}}warn{{else}}none{{end}}">
    <strong>{{if .Attention.Category}}{{.Attention.Category}}{{else}}attention{{end}}</strong>: {{.Attention.Summary}}
    {{if .Attention.Hint}}<br>{{.Attention.Hint}}{{end}}
  </div>
  {{end}}
</section>
<section class="panel">
  <h2>Operational Checks</h2>
  <p><strong>{{if .OperationalOverall}}{{.OperationalOverall}}{{else}}unknown{{end}}</strong>{{if .OperationalSummary}}: {{.OperationalSummary}}{{end}}</p>
  <table>
    <tr><th>Check</th><th>Level</th><th>Summary</th><th>Guidance</th></tr>
    {{range .OperationalChecks}}
    <tr>
      <td class="mono">{{.ID}}</td>
      <td class="mono">{{.Level}}</td>
      <td>{{.Summary}}</td>
      <td>{{if .Hint}}{{.Hint}}{{else}}-{{end}}</td>
    </tr>
    {{end}}
  </table>
</section>
<section class="panel">
  <h2>Detailed Status</h2>
  <table>
    <tr><th>Installation ID</th><td class="mono">{{if .Snapshot.InstallationID}}{{.Snapshot.InstallationID}}{{else}}unknown{{end}}</td></tr>
    <tr><th>Local Name</th><td>{{if .Snapshot.LocalName}}{{.Snapshot.LocalName}}{{else}}unnamed{{end}}</td></tr>
    <tr><th>Hostname</th><td class="mono">{{if .Snapshot.Hostname}}{{.Snapshot.Hostname}}{{else}}unknown{{end}}</td></tr>
    <tr><th>Cloud Receiver ID</th><td class="mono">{{if .Snapshot.CloudReceiverID}}{{.Snapshot.CloudReceiverID}}{{else}}not assigned{{end}}</td></tr>
    <tr><th>Cloud Receiver Name</th><td>{{if .Snapshot.CloudReceiverLabel}}{{.Snapshot.CloudReceiverLabel}}{{else}}not assigned{{end}}</td></tr>
    <tr><th>Cloud Site</th><td>{{if .Snapshot.CloudSiteLabel}}{{.Snapshot.CloudSiteLabel}}{{else}}not set{{end}}</td></tr>
    <tr><th>Cloud Group</th><td>{{if .Snapshot.CloudGroupLabel}}{{.Snapshot.CloudGroupLabel}}{{else}}not set{{end}}</td></tr>
    <tr><th>Ready</th><td>{{if .Snapshot.Ready}}yes{{else}}no{{end}} {{if .Snapshot.ReadyReason}}({{.Snapshot.ReadyReason}}){{end}}</td></tr>
    <tr><th>Cloud Reachable</th><td>{{if .Snapshot.CloudReachable}}yes{{else}}no{{end}}</td></tr>
    <tr><th>Heartbeat Fresh</th><td>{{if .Snapshot.HeartbeatFresh}}yes{{else}}no{{end}}</td></tr>
    <tr><th>Last Heartbeat Ack</th><td class="mono">{{if .Snapshot.LastHeartbeatAck}}{{.Snapshot.LastHeartbeatAck}}{{else}}none{{end}}</td></tr>
    <tr><th>Ingest Queue Depth</th><td>{{.Snapshot.IngestQueueDepth}}</td></tr>
    <tr><th>Last Packet Ack</th><td class="mono">{{if .Snapshot.LastPacketAck}}{{.Snapshot.LastPacketAck}}{{else}}none{{end}}</td></tr>
    <tr><th>Started At</th><td class="mono">{{.Snapshot.StartedAt}}</td></tr>
    <tr><th>Updated At</th><td class="mono">{{.Snapshot.UpdatedAt}}</td></tr>
    <tr><th>Cloud Endpoint</th><td class="mono">{{.Snapshot.CloudEndpoint}}</td></tr>
    <tr><th>Mode</th><td class="mono">{{.Snapshot.Mode}}</td></tr>
    <tr><th>Runtime Profile</th><td class="mono">{{.Snapshot.RuntimeProfile}}</td></tr>
    <tr><th>Issue Summary</th><td>{{if .Snapshot.FailureSummary}}{{.Snapshot.FailureSummary}}{{else}}none{{end}}</td></tr>
    <tr><th>Issue Guidance</th><td>{{if .Snapshot.FailureHint}}{{.Snapshot.FailureHint}}{{else}}none{{end}}</td></tr>
    <tr><th>Attention State</th><td class="mono">{{if .Attention.State}}{{.Attention.State}}{{else}}none{{end}}</td></tr>
    <tr><th>Attention Category</th><td class="mono">{{if .Attention.Category}}{{.Attention.Category}}{{else}}none{{end}}</td></tr>
    <tr><th>Attention Summary</th><td>{{if .Attention.Summary}}{{.Attention.Summary}}{{else}}none{{end}}</td></tr>
    <tr><th>Attention Guidance</th><td>{{if .Attention.Hint}}{{.Attention.Hint}}{{else}}none{{end}}</td></tr>
    <tr><th>Update Summary</th><td>{{if .Snapshot.UpdateSummary}}{{.Snapshot.UpdateSummary}}{{else}}none{{end}}</td></tr>
    <tr><th>Update Guidance</th><td>{{if .Snapshot.UpdateHint}}{{.Snapshot.UpdateHint}}{{else}}none{{end}}</td></tr>
    <tr><th>Recommended Version</th><td class="mono">{{if .Snapshot.UpdateRecommendedVersion}}{{.Snapshot.UpdateRecommendedVersion}}{{else}}unknown{{end}}</td></tr>
    <tr><th>Manifest Channel</th><td class="mono">{{if .Snapshot.UpdateManifestChannel}}{{.Snapshot.UpdateManifestChannel}}{{else}}unknown{{end}}</td></tr>
    <tr><th>Last Update Check</th><td class="mono">{{if .Snapshot.UpdateCheckedAt}}{{.Snapshot.UpdateCheckedAt}}{{else}}never{{end}}</td></tr>
    <tr><th>Last Error</th><td>{{if .Snapshot.LastError}}{{.Snapshot.LastError}}{{else}}none{{end}}</td></tr>
  </table>
</section>
{{end}}
