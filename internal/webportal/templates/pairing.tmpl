{{define "content"}}
<section class="panel">
  <h2>Pair This Receiver</h2>
  <p>Paste the pairing code from LoRaMapr Cloud to link this installation to your account.</p>
  <p class="muted">For local/self-hosted cloud testing, set cloud base URL during bootstrap with <span class="mono">--cloud-base-url</span> (no manual config editing needed).</p>
  {{if .Flash}}
  <div class="hint {{.FlashClass}}">{{.Flash}}</div>
  {{end}}
  <form method="post" action="/pairing">
    <label for="pairing_code">Pairing Code</label>
    <input id="pairing_code" name="pairing_code" type="text" placeholder="LMR-..." maxlength="128" required>
    <button type="submit">Submit Pairing Code</button>
  </form>
</section>
<section class="panel">
  <h2>Current Receiver Status</h2>
  <table>
    <tr><th>Local Receiver Name</th><td>{{if .Snapshot.LocalName}}{{.Snapshot.LocalName}}{{else}}unnamed{{end}}</td></tr>
    <tr><th>Cloud Receiver</th><td>{{if .Snapshot.CloudReceiverLabel}}{{.Snapshot.CloudReceiverLabel}}{{else if .Snapshot.CloudReceiverID}}{{.Snapshot.CloudReceiverID}}{{else}}not assigned yet{{end}}</td></tr>
    <tr><th>Cloud Endpoint</th><td class="mono">{{.Snapshot.CloudEndpoint}}</td></tr>
    <tr><th>Pairing Phase</th><td class="mono">{{.Snapshot.PairingPhase}}</td></tr>
    <tr><th>Cloud Status</th><td>{{.Snapshot.CloudStatus}}</td></tr>
    <tr><th>Service Status</th><td>{{.Snapshot.Lifecycle}}</td></tr>
    <tr><th>Last Runtime Error</th><td>{{if .Snapshot.LastError}}{{.Snapshot.LastError}}{{else}}none{{end}}</td></tr>
  </table>
</section>
{{end}}
