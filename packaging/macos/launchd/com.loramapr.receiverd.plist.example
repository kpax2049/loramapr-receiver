<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
  <dict>
    <key>Label</key>
    <string>com.loramapr.receiverd</string>
    <key>ProgramArguments</key>
    <array>
      <string>/usr/local/bin/loramapr-receiverd</string>
      <string>run</string>
      <string>-config</string>
      <string>/usr/local/etc/loramapr/receiver.json</string>
    </array>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
  </dict>
</plist>
