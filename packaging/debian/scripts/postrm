#!/bin/sh
set -eu

if command -v systemctl >/dev/null 2>&1; then
  systemctl daemon-reload || true
fi

case "${1:-}" in
  purge)
    rm -f /etc/loramapr/receiver.json || true
    rm -f /var/lib/loramapr/receiver-state.json || true
    rm -rf /var/lib/loramapr /var/log/loramapr || true
    rmdir /etc/loramapr >/dev/null 2>&1 || true
    ;;
esac

exit 0
