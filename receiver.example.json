{
  "schema_version": 2,
  "service": {
    "mode": "auto",
    "heartbeat": "30s"
  },
  "runtime": {
    "profile": "auto",
    "local_name": ""
  },
  "paths": {
    "state_file": "./data/receiver-state.json"
  },
  "portal": {
    "bind_address": "127.0.0.1:8080"
  },
  "cloud": {
    "base_url": "https://api.loramapr.example"
  },
  "update": {
    "enabled": false,
    "manifest_url": "https://downloads.loramapr.com/receiver/stable/latest/cloud-manifest.fragment.json",
    "check_interval": "6h",
    "request_timeout": "4s",
    "min_supported_version": ""
  },
  "meshtastic": {
    "transport": "serial",
    "device": "/dev/ttyUSB0"
  },
  "logging": {
    "level": "info",
    "format": "json"
  }
}
