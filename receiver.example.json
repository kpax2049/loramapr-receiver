{
  "service": {
    "mode": "auto",
    "heartbeat": "30s"
  },
  "paths": {
    "state_file": "./data/receiver-state.json"
  },
  "portal": {
    "bind_address": "127.0.0.1:8080"
  },
  "cloud": {
    "base_url": "https://api.loramapr.example"
  },
  "meshtastic": {
    "transport": "serial",
    "device": "/dev/ttyUSB0"
  },
  "logging": {
    "level": "info",
    "format": "json"
  }
}
